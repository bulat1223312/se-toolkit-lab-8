{
  "providers": {
    "custom": {
      "apiKey": "${LLM_API_KEY}",
      "apiBase": "${LLM_API_BASE_URL}"
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790
  },
  "agents": {
    "defaults": {
      "model": "coder-model"
    }
  },
  "channels": {
    "webchat": {
      "host": "0.0.0.0",
      "port": 8765
    }
  },
  "tools": {
    "mcpServers": {
      "lms": {
        "command": "python",
        "args": ["-m", "mcp_lms"],
        "env": {
          "NANOBOT_LMS_BACKEND_URL": "${NANOBOT_LMS_BACKEND_URL}",
          "NANOBOT_LMS_API_KEY": "${NANOBOT_LMS_API_KEY}"
        }
      }
    }
  }
}

